{
  "name": "worktree-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "Worktree version control system - monorepo",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "clean": "turbo run clean && rm -rf node_modules",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,md,css}\"",
    "test": "turbo run test"
  },
  "devDependencies": {
    "@types/node": "^20.11.5",
    "prettier": "^3.1.1",
    "turbo": "^1.11.3",
    "typescript": "^5.3.3"
  },
  "packageManager": "pnpm@8.15.0",
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*",
    "crates/worktree-admin"
  ]
}
