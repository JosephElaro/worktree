{
  "name": "worktree-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "Worktree version control system - monorepo",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "clean": "turbo run clean && rm -rf node_modules",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,md,css}\"",
    "test": "turbo run test"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "prettier": "^3.8.1",
    "turbo": "^2.8.20",
    "typescript": "^6.0.2",
    "next": "^16.2.1"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "workspaces": [
    "apps/web",
    "crates/worktree-admin"
  ]
}
